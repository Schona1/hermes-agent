# ================================================
# SOCIAL MEDIA AGENT — CONFIGURATION
# ================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. Never share your .env file with anyone
# ================================================

# ── REQUIRED ────────────────────────────────────

# Claude AI — get your key at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot — create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your personal Telegram user ID (see SETUP.md for how to find this)
TELEGRAM_CHAT_ID=your_chat_id_here

# ── YOUR BRAND ───────────────────────────────────

NICHE=Business / Entrepreneurship
BRAND_NAME=Your Brand Name
WEBSITE_URL=https://yourwebsite.com
YOUTUBE_CHANNEL_URL=https://youtube.com/@yourchannel
TARGET_AUDIENCE=entrepreneurs, business owners, and aspiring professionals
BRAND_VOICE=authentic, direct, and value-driven

# ── SCHEDULING ───────────────────────────────────

# Time to auto-generate content each day (24-hour format)
DAILY_GENERATE_TIME=08:00
# Your timezone — full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
POSTING_TIMEZONE=America/New_York

# ── TWITTER / X ──────────────────────────────────
# Get keys at: developer.twitter.com → Your App → Keys and Tokens
# Requires a Free or Basic developer account

TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ── FACEBOOK PAGE ────────────────────────────────
# Get at: developers.facebook.com → Your App → Tools → Graph API Explorer
# Requires a Facebook Business Page (not personal profile)

FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ── INSTAGRAM ────────────────────────────────────
# Uses the same Meta Developer App as Facebook
# Requires an Instagram Professional (Business or Creator) account
# connected to your Facebook Page

INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=

# ── LINKEDIN ─────────────────────────────────────
# Get at: developer.linkedin.com → Your App → Auth tab
# Requires the 'w_member_social' permission

LINKEDIN_ACCESS_TOKEN=
# Find your URN at: linkedin.com/in/your-profile → click 'More' → 'Save to PDF'
# Or use: https://api.linkedin.com/v2/me (with your token)
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXX

# ── TIKTOK (Optional) ────────────────────────────
# TikTok scripts are generated automatically.
# Direct posting via API requires TikTok Content Posting API approval.
# Alternative: use Buffer or Later to schedule TikTok posts.

TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

# ── DATABASE ─────────────────────────────────────
# SQLite file path — no changes needed unless you want a custom location
DATABASE_PATH=social_media_agent.db
